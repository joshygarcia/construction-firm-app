{
  "name": "construction-firm-app",
  "productName": "Control Central",
  "version": "0.6.0",
  "private": true,
  "main": "electron/dist/main.js",
  "updater": {
    "owner": "joshygarcia",
    "repo": "construction-firm-app",
    "assetName": "Control-Central-windows-x64.zip"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k -n next,electron -c blue,magenta \"next dev\" \"wait-on http://127.0.0.1:3000 && npm run electron:compile && electron electron/dist/main.js\"",
    "electron:build": "next build && node scripts/copy-standalone-assets.mjs && npm run electron:compile",
    "dist": "npm run electron:build && node scripts/package-electron.mjs",
    "dist:zip": "npm run dist && node scripts/zip-dist.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.controlcentral.app",
    "productName": "Control Central",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
